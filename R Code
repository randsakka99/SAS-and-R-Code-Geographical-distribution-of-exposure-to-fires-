#Population shifts. The code below assesses how changes in population contribute to changes in person-day exposure and corresponds to Equations 4–6 in the manuscript.
#Entire study region
#EQUATION 4
model1 <- lmer(
  PersonDayExp ~ Year + (1 | GEOID10) + (0 + Year | GEOID10),
  data = data,
  REML = FALSE  
)
summary(model1)
#EQUATION 5
model2 <- lmer(
  PersonDayExp ~ Population + Year +  (1 | GEOID10) + (0 + Year | GEOID10),
  data = data,
  REML = FALSE
)
summary(model2)
#EQUATION 6 
beta_t_unadj <- fixef(model1)["Year"] 
beta_t_adj <- fixef(model2)["Year"] 
percent_explained <- (beta_t_unadj - beta_t_adj) / beta_t_unadj 
percent_explained


#Figure 1A: Person-day exposure map
Figure1A <- data[, c("GEOID10", "LONGITUDE", "LATITUDE", "PersonDayExp")]

Figure1A <- Figure1A %>%
  group_by(GEOID10) %>%
  summarise(
    Longitude = first(LONGITUDE),
    Latitude  = first(LATITUDE),
    PersonDayExp = sum(PersonDayExp, na.rm = TRUE),
    .groups = "drop"
  )


Outlier_Counties <- c("12015", "12043", "12051", "12097", "12099")

# 2. FILTER TO OUTLIER TRACTS
tract_crop <- tracts_outliers %>%
filter(GEOID10 %in% Outlier_GEOID10s)

# 3. GET Cropland data layer and extract crops per county
crop_tract_list <- list()

for(i in seq_along(Outlier_Counties)){
  
this_county <- Outlier_Counties[i]
county_code <- substr(this_county, 3, 5)
  
# Filter tracts for this county
tracts_this <- tract_crop %>%
filter(STATEFP10 == "12" & COUNTYFP10 == county_code) %>%
st_transform(crs(cdl))
  
if(nrow(tracts_this) == 0) next
  
# Convert to SpatVector for terra crop()
tracts_vect <- vect(tracts_this)
  
# Crop CDL to this county's tracts
cdl_county <- crop(cdl, tracts_vect)
  
# Define dominant crops
sugarcane <- cdl_county == 45
hay       <- cdl_county %in% c(37, 176)
  
# Extract areas
tracts_this$sugarcane_prop <- exact_extract(
sugarcane, tracts_this,
function(v, w) sum(v * w, na.rm = TRUE)
)

tracts_this$hay_prop <- exact_extract(
hay, tracts_this,
function(v, w) sum(v * w, na.rm = TRUE)
)
  
# Store results
crop_tract_list[[i]] <- tracts_this
}


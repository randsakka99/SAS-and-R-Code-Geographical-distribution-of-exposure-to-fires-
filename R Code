#Figure 2A
Figure2A <- data %>% mutate(GEOID10 = sprintf("%011.0f", GEOID10))

trend <- Figure2A %>% 
group_by(GEOID10) %>% 
group_modify(~{ 
fit <- try(lm(PersonDayExp ~ Year, data = .x), silent = TRUE) 
if(inherits(fit, "try-error")) return(tibble(Estimate = NA, pValue = NA)) 
tidy_fit <- broom::tidy(fit) 
tibble( 
Estimate = tidy_fit$estimate[tidy_fit$term == "Year"], 
pValue = tidy_fit$p.value[tidy_fit$term == "Year"] 
) 
}) %>% 
ungroup() %>% 
filter(pValue < 0.05) %>% 
mutate( 
color_raw = round(log(abs(Estimate)), 1), 
color = cut( 
color_raw, 
breaks = seq(min(color_raw), max(color_raw), length.out = 14), 
labels = FALSE, 
include.lowest = TRUE 
), 
st = substr(GEOID10, 1, 2) 
) %>% 
filter(is.finite(color_raw))

trend <- trend %>% mutate(GEOID10 = as.character(GEOID10))


#Figure 2A
Figure2A <- data %>% mutate(GEOID10 = sprintf("%011.0f", GEOID10))

trend <- Figure2A %>% 
group_by(GEOID10) %>% 
group_modify(~{ 
fit <- try(lm(PersonDayExp ~ Year, data = .x), silent = TRUE) 
if(inherits(fit, "try-error")) return(tibble(Estimate = NA, pValue = NA)) 
tidy_fit <- broom::tidy(fit) 
tibble( 
Estimate = tidy_fit$estimate[tidy_fit$term == "Year"], 
pValue = tidy_fit$p.value[tidy_fit$term == "Year"] 
) 
}) %>% 
ungroup() %>% 
filter(pValue < 0.05) %>% 
mutate( 
color_raw = round(log(abs(Estimate)), 1), 
color = cut( 
color_raw, 
breaks = seq(min(color_raw), max(color_raw), length.out = 14), 
labels = FALSE, 
include.lowest = TRUE 
), 
st = substr(GEOID10, 1, 2) 
) %>% 
filter(is.finite(color_raw))

trend <- trend %>% mutate(GEOID10 = as.character(GEOID10))

us_states_eqarea <- states(cb = TRUE, year=2010) %>%
shift_geometry(preserve_area = FALSE)
us_states_eq <- filter(us_states_eqarea,!STATE %in% c("72"))

d_pal <- colorRampPalette(c("#CCEEF9","#4285f4"))
d_colors <- d_pal(13)

u_pal <- colorRampPalette(c("#FFC1C1","#ea4335"))
u_colors <- u_pal(13)

fire_state <- sort(unique(trend$st))

layout(matrix(c(1,2), nrow = 2), heights = c(4,1))

plot(us_states_eq$geometry, col = "white" , border = "#D3D3D3", bg = "white")

for (s in fire_state) { 
tracts_sf <- tracts(state = s, year = 2010) %>% 
shift_geometry(preserve_area = FALSE) %>%
mutate(GEOID10 = as.character(GEOID10))
  
together <- tracts_sf %>% 
left_join(trend, by = "GEOID10") 
  
down <- filter(together, Estimate < 0) 
if (nrow(down) > 0) { 
fire_d <- d_colors[down$color] 
plot(down$geometry, add = TRUE, col = fire_d, border = NA) 
} 
  
up <- filter(together, Estimate > 0) 
if (nrow(up) > 0) { 
fire_u <- u_colors[up$color] 
plot(up$geometry, add = TRUE, col = fire_u, border = NA) 
} 
}

par(mar = c(3, 5, 1, 5))  

legend_cols <- colorRampPalette(c("#4285f4", "white", "#ea4335"))(100)

x <- seq(-1, 1, length.out = 100)
y <- 1
z <- matrix(x, nrow = length(x), ncol = length(y))

image(
  x = x,
  y = y,
  z = z,
  col = legend_cols,
  axes = FALSE,
  xlab = "",
  ylab = ""
)
axis(
  side = 1,
  at = c(-1, 0, 1),
  labels = c("Decreasing trend", "No change", "Increasing trend"),
  cex.axis = 0.9
)
mtext(
  "Changes in person-day exposure to fires [log] (significant tracts only)",
  side = 1,
  line = 2,
  cex = 0.9

#Figure 1B: Bar chart
Figure1B<- data[, c("Region", "PersonDayExp")]

Figure1B <- Figure1B %>%
  group_by(Region) %>%
  summarise(
    PersonDayExp = sum(PersonDayExp, na.rm = TRUE),
    .groups = "drop"
  )

Figure1B <- Figure1B %>%
  mutate(PersonDayExp_Billions = PersonDayExp / 1000000000)

Figure1B <- Figure1B %>%
  mutate(
    Region = case_when(
      Region == "North" ~ "Northeast",
      Region == "Midwe" ~ "Midwest",
      TRUE ~ Region
    )
  )

Figure1B <- Figure1B %>%
  mutate(
    Region = factor(
      Region,
      levels = c("Northeast", "West", "Midwest", "South")
    )
  )

Figure1B <- Figure1B %>%
  mutate(
    PersonDayExp_label = format(PersonDayExp, big.mark = ",")
  )

Figure1B <- Figure1B %>%
  mutate(
    Percent_total = PersonDayExp / sum(PersonDayExp) * 100,
    Percent_label = paste0(round(Percent_total), "%"),
    PersonDayExp_label = paste0(
      format(PersonDayExp, big.mark = ","),
      "\n",
      Percent_label
    )
  )

ggplot(Figure1B, aes(x = PersonDayExp_Billions, y = Region, fill = Region)) +
  geom_col() +
  geom_text(
    aes(label = PersonDayExp_label),
    hjust = -0.05,
    size = 3.5,
    lineheight = 0.9
  ) +
  scale_fill_manual(values = c(
    "Northeast" = "orange",
    "West" = "gold",
    "Midwest" = "steelblue",
    "South" = "forestgreen"
  )) +
  scale_x_continuous(
    limits = c(0, 6),
    breaks = seq(0, 6, by = 1),
    expand = expansion(mult = c(0, 0.08))
  ) +
  labs(
    x = "Person-days of exposure to fires (billions)",
    y = NULL
  ) +
  theme_minimal(base_size = 12) +
  theme(
    legend.position = "none",
    panel.grid.major = element_blank(),
    panel.grid.minor = element_blank()
  )

